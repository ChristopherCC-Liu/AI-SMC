# MT5 Connection (Windows VPS only)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Runtime
SMC_ENV=dev                    # dev | paper | live
SMC_DATA_DIR=./data
SMC_LOG_LEVEL=INFO
SMC_MT5_MOCK=1                 # 1=mock (macOS dev), 0=real MT5

# Risk
SMC_RISK_PER_TRADE_PCT=1.0
SMC_MAX_DAILY_LOSS_PCT=3.0
SMC_MAX_DRAWDOWN_PCT=10.0
SMC_MAX_LOT_SIZE=0.01

# LLM (Phase 3+)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
SMC_LLM_DAILY_BUDGET_USD=5.0

# Alerting (Phase 4)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
