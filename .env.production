# ═══════════════════════════════════════════════════════════════════════════════
# AI-SMC Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
#
# All variables use the SMC_ prefix (matching pydantic-settings env_prefix).
# ═══════════════════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────────────────
SMC_ENV=paper                  # paper = demo trading, live = real money (DO NOT use live for v1)
SMC_MT5_MOCK=0                 # 0 = connect to real MT5 Terminal (Windows only)
SMC_DATA_DIR=./data            # Local data lake directory (parquet files)
SMC_LOG_LEVEL=INFO             # DEBUG for troubleshooting, INFO for normal operation

# ── MT5 Connection ────────────────────────────────────────────────────────────
# Get these from your TMGM Demo account.
# Login to MT5 Terminal first to verify credentials work.
SMC_MT5_LOGIN=                 # Your MT5 demo account number (e.g. 12345678)
SMC_MT5_PASSWORD=              # Your MT5 demo account password
SMC_MT5_SERVER=TMGM-Demo      # Broker server (use exactly as shown in MT5 Terminal)

# ── Risk Management (CONSERVATIVE for demo) ──────────────────────────────────
SMC_RISK_PER_TRADE_PCT=1.0    # Risk 1% of equity per trade
SMC_MAX_DAILY_LOSS_PCT=3.0    # Halt after 3% daily loss
SMC_MAX_DRAWDOWN_PCT=10.0     # Halt after 10% drawdown from equity peak
SMC_MAX_LOT_SIZE=0.01         # Maximum 0.01 lots per order (micro lot)

# ── AI Regime Classifier ─────────────────────────────────────────────────────
# Disabled for v1 deploy. Enable for v1.1+ after validation.
SMC_AI_REGIME_ENABLED=0       # 0 = use ATR-based regime fallback, 1 = use LLM classifier

# ── LLM (disabled for v1, enable for v1.1+) ──────────────────────────────────
# ANTHROPIC_API_KEY=           # Uncomment and set when enabling AI features
# SMC_ANTHROPIC_MODEL=claude-opus-4-6
# SMC_LLM_DAILY_BUDGET_USD=5.0

# ── Telegram Alerts (optional) ────────────────────────────────────────────────
# Set up a Telegram bot via @BotFather, then get your chat ID.
# See docs/VPS_DEPLOYMENT.md for detailed instructions.
SMC_TELEGRAM_BOT_TOKEN=       # From @BotFather (e.g. 123456:ABC-DEF...)
SMC_TELEGRAM_CHAT_ID=         # Your chat/channel ID (e.g. -1001234567890)
